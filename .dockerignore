# This file excludes paths from the Docker build context.
#
# By default, Docker's build context includes all files (and folders) in the
# current directory. Even if a file isn't copied into the container it is still sent
# to the Docker daemon.
#
# There are multiple reasons to exclude files from the build context:
#
# 1. Prevent sending unnecessary files to the daemon.
# 2. Improve the speed of 'ADD' and 'COPY' operations.
# 3. Prevent re-builds when only irrelevant files have changed.

# Common VCS dirs
.git/
.gitignore

# Common IDE dirs
.vscode/
.idea/

# Build artifacts
_build/
deps/
*.o
*.beam
/assets/node_modules/

# Generated on crash by the VM
erl_crash.dump

# Static artifacts - These should be fetched and built inside Docker
/priv/static/assets/

# Files not needed for production builds
/test/
/tmp/
/.github/
/docker-compose*
fly.toml
Dockerfile
.dockerignore
.tool-versions
.env
